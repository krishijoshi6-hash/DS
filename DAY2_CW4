
def binary_search(words, target):
    left = 0
    right = len(words) - 1

    while left <= right:
        mid = (left + right) // 2

        if words[mid] == target:
            return mid
        elif words[mid] < target:
            left = mid + 1
        else:
            right = mid - 1

    return -1  # Word not found


# Example: A sorted list of dictionary words
dictionary = [
    "Apple", "Banana", "Cat", "Dog",
    "Elephant", "Ephemeral", "Fish",
    "Monkey", "Tiger", "Zebra"
]

word = "Ephemeral"
index = binary_search(dictionary, word)

if index != -1:
    print(f'"{word}" found at index {index}')
else:
    print(f'"{word}" not found')
